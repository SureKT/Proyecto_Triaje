# ── Postgres ──────────────────────────────────────────────────────────────────
POSTGRES_USER=triaje
POSTGRES_PASSWORD=triaje_pass
POSTGRES_DB=triaje_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── MinIO ──────────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET_TEXTOS=textos-originales
MINIO_BUCKET_DATASETS=datasets
MINIO_BUCKET_MODELOS=modelos

# ── LLM ───────────────────────────────────────────────────────────────────────
# PC casa con GPU → usar Ollama (sin límites, sin datos a terceros)
# Portátil sin GPU / defensa → usar OpenRouter (rápido, 3 predicciones demo = sin riesgo 429)
LLM_PROVIDER=ollama

# OpenRouter — https://openrouter.ai/keys
# Activar en portátil: cambiar LLM_PROVIDER=openrouter y rellenar la key
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=google/gemini-2.0-flash-001
# Alternativas rápidas: anthropic/claude-haiku-3, meta-llama/llama-3.1-8b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_APP_NAME=Triaje IA
OPENROUTER_HTTP_REFERER=http://localhost
LLM_MAX_RETRIES=4
LLM_RETRY_BASE_SEC=15
LLM_BATCH_LIMIT=0
LLM_DELAY_SEC=0
# Con OpenRouter free en demo usar LLM_DELAY_SEC=2 por precaución

# Ollama local (solo si LLM_PROVIDER=ollama) — requiere GPU en el host
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.1:8b

# ── Airflow ────────────────────────────────────────────────────────────────────
AIRFLOW_UID=50000
AIRFLOW__CORE__FERNET_KEY=
AIRFLOW__WEBSERVER__SECRET_KEY=

# ── API interna ────────────────────────────────────────────────────────────────
API_BASE_URL=http://api:8000
